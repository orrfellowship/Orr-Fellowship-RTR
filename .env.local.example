# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets — NEVER prefixed NEXT_PUBLIC
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JAZZHR_API_KEY=your-jazzhr-key
# Optional fallback used by JazzHR resume/document endpoints.
JAZZHR_SANDCASTLE_TICKET=your-jazzhr-sandcastle-ticket

# Public site URL — used to build email links and by pg_cron
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Resend for RTR transactional system email only
RESEND_API_KEY=
RESEND_FROM_EMAIL=Orr Recruiting <admin@recruiting.orrfellowship.org>

# Google OAuth for per-user Gmail connection (server-only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
# Generate with: openssl rand -base64 32
GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY=
# Set true only while intentionally sending the fictional mock campaign to controlled test inboxes.
ENABLE_GMAIL_TEST_SEND=false

# Shared secret the /api/cron route checks (Bearer token from pg_cron)
CRON_SECRET=generate-a-long-random-string

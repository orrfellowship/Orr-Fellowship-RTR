# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets — NEVER prefixed NEXT_PUBLIC
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JAZZHR_API_KEY=your-jazzhr-key
# Optional fallback used by JazzHR resume/document endpoints.
JAZZHR_SANDCASTLE_TICKET=your-jazzhr-sandcastle-ticket

# Public site URL — used to build email links and by pg_cron
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# SMTP for transactional email (same credentials as Supabase Auth SMTP)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM="Orr Recruiting <recruiting@your-domain.com>"

# Shared secret the /api/cron route checks (Bearer token from pg_cron)
CRON_SECRET=generate-a-long-random-string

# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets — NEVER prefixed NEXT_PUBLIC
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JAZZHR_API_KEY=your-jazzhr-key
# Optional fallback used by JazzHR resume/document endpoints.
JAZZHR_SANDCASTLE_TICKET=your-jazzhr-sandcastle-ticket

# Public site URL — used to build email links and by pg_cron
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Resend for RTR transactional system email only
RESEND_API_KEY=
RESEND_FROM_EMAIL=Orr Recruiting <admin@recruiting.orrfellowship.org>

# Shared secret the /api/cron route checks (Bearer token from pg_cron)
CRON_SECRET=generate-a-long-random-string

# Gmail outreach (per-fellow OAuth — human outreach lane, separate from Resend)
# Encrypts stored refresh tokens at rest. Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
# Google Cloud OAuth client (Internal consent screen on the Orr Workspace domain)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.vercel.app/api/gmail/callback

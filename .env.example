# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets — NEVER prefixed NEXT_PUBLIC
SUPABASE_SERVICE_ROLE_KEY=
JAZZHR_API_KEY=
JAZZHR_SANDCASTLE_TICKET=

# Public site URL
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Resend transactional system email (unrelated to Gmail campaign OAuth)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Orr Recruiting <admin@recruiting.orrfellowship.org>

# Google OAuth for per-user Gmail connection
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY=

CRON_SECRET=
